SQLITE_HOST=<your_key_here>
SQLITE_PORT=<your_key_here>
SQLITE_API_KEY=<your_key_here>
SQLITE_DB=<your_source_db_here>
SQLITE_METADATA_DB=<your_metadata_db_here>
DB_NAME=<your_db_name_here>
PINECONE_API_KEY=<your_key_here>
PINECONE_INDEX_NAME=<your_index_name_here>
NEO4J_URL=<your_neo4j_url_here>
NEO4J_USERNAME=<your_neo4j_username_here>
NEO4J_PASSWORD=<your_neo4j_password_here>
