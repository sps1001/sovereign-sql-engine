# Grafana Cloud Prometheus remote_write settings
# Use the exact Grafana Cloud Prometheus push endpoint, ending in /api/prom/push.
GRAFANA_CLOUD_PROM_REMOTE_WRITE_URL=<URL_HERE>
GRAFANA_CLOUD_PROM_USERNAME=<USERNAME_HERE>
GRAFANA_CLOUD_PROM_API_KEY=<API_TOKEN>

# Grafana Cloud Loki push settings
# Use the exact Grafana Cloud Loki push endpoint, ending in /loki/api/v1/push.
GRAFANA_CLOUD_LOKI_URL=<URL_HERE>
GRAFANA_CLOUD_LOKI_USERNAME=<USERNAME_HERE>
GRAFANA_CLOUD_LOKI_API_KEY=<API_TOKEN>