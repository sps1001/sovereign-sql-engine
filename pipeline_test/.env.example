LOG_LEVEL=INFO

DB_NAME=<your_db_filter_name_here>

SQLITE_HOST=<your_sqlite_cloud_host_here>
SQLITE_PORT=<your_sqlite_cloud_port_here>
SQLITE_API_KEY=<your_sqlite_cloud_api_key_here>
SQLITE_METADATA_DB=<your_metadata_db_here>

PINECONE_API_KEY=<your_pinecone_api_key_here>
PINECONE_INDEX_NAME=<your_pinecone_index_name_here>
# Optional: use this instead of PINECONE_INDEX_NAME if you already know the host
# PINECONE_INDEX_HOST=<your_pinecone_index_host_here>
PINECONE_NAMESPACE=metadata
PINECONE_EMBED_MODEL=llama-text-embed-v2
PINECONE_RERANK_MODEL=pinecone-rerank-v0

LLAMA_GUARD_URL=<your_modal_llama_guard_base_url_here>
LLAMA_GUARD_MODEL=llm

PHI4_URL=<your_modal_phi4_base_url_here>
PHI4_MODEL=llm

NEO4J_URL=<your_neo4j_url_here>
NEO4J_USERNAME=<your_neo4j_username_here>
NEO4J_PASSWORD=<your_neo4j_password_here>

RUNPOD_API_KEY=<your_runpod_api_key_here>
RUNPOD_ENDPOINT_ID=nbnl7ipqazrjp8
RUNPOD_BASE_URL=https://api.runpod.ai/v2
RUNPOD_STATUS_POLL_INTERVAL=2
RUNPOD_STATUS_TIMEOUT=300

TOP_K_COLUMNS=8
TOP_K_TABLES=5
INITIAL_RETRIEVAL_MULTIPLIER=3

QWEN3_API_TOKEN=<your_qwen_or_openai_api_token_here>
QWEN3_BASE_URL=https://api.openai.com/v1
